
JWT_SECRET=your-jwt-secret-key-here
NODE_ENV=development
PORT=3000

FRONTEND_URL=http://localhost:5173

LOG_LEVEL=info

AI_ENGINE_URL=http://localhost:5000
AI_ENGINE_PORT=5000
FLASK_ENV=development

# OpenWeatherMap — unified live weather + AQI/air pollution (required)
OPENWEATHERMAP_API_KEY=
OWM_CACHE_TTL_MS=25000
OWM_HEX_BATCH_SIZE=4
OWM_BATCH_DELAY_MS=120
HUGGINGFACE_API_TOKEN=
HUGGINGFACE_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=BioSafetyPlatform/1.0 (educational)
OVERPASS_URL=https://overpass-api.de/api/interpreter
OVERPASS_MIRRORS=https://overpass.kumi.systems/api/interpreter
OVERPASS_TIMEOUT_MS=35000
CROWD_CACHE_TTL_MS=120000
OSRM_URL=https://router.project-osrm.org

DEFAULT_LAT=12.9716
DEFAULT_LNG=77.5946
MONITOR_RADIUS_KM=5
H3_RING_SIZE=
MAX_HEX_CELLS=200
OWM_HEX_DELAY_MS=80
CROWD_HEX_DELAY_MS=100
POLL_INTERVAL_MS=30000
